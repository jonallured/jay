{
  "name": "@jonallured/jay",
  "description": "Various cli tricks and stunts.",
  "version": "0.2.0",
  "author": "Jon Allured @jonallured",
  "bin": {
    "jay": "./bin/run"
  },
  "bugs": "https://github.com/jonallured/jay/issues",
  "dependencies": {
    "@oclif/core": "^3.21.0",
    "@oclif/plugin-help": "^6.0.15",
    "@octokit/rest": "^20.0.2",
    "node-fetch": "3.3.2",
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@oclif/test": "^3.2.1",
    "@octokit/types": "^12.6.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "directory-tree": "^3.5.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "globby": "^14.0.1",
    "jest": "^29.7.0",
    "oclif": "^4.4.21",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=8.0.0"
  },
  "files": [
    "/bin",
    "/lib",
    "/npm-shrinkwrap.json",
    "/oclif.manifest.json"
  ],
  "homepage": "https://github.com/jonallured/jay",
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts",
      "tsx"
    ],
    "testEnvironment": "node",
    "testRegex": ".test\\.(ts|js)$",
    "transform": {
      "^.+\\.(ts|tsx|js|jsx)$": "ts-jest"
    }
  },
  "keywords": [
    "oclif"
  ],
  "license": "MIT",
  "main": "lib/index.js",
  "oclif": {
    "commands": "./lib/commands",
    "bin": "jay",
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topics": {
      "keys": {
        "description": "Manage authorized keys."
      },
      "feature": {
        "description": "Setup feature branches and PRs."
      },
      "sharpen": {
        "description": "Sharpen your tools."
      }
    }
  },
  "repository": "jonallured/jay",
  "prettier": {
    "semi": false
  },
  "scripts": {
    "build": "tsc && oclif manifest",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "prettier": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "prettier-check": "prettier --check 'src/**/*.ts' 'test/**/*.ts'",
    "test": "jest",
    "test:watch": "jest --watch",
    "type-check": "tsc --pretty --noEmit"
  },
  "types": "lib/index.d.ts"
}
